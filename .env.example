APP_NAME="Adonis"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL="https://adonis.com.bd"

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_TIMEOUT=3

# MySQL CMS database. Defaults are suitable for local XAMPP if unchanged.
MYSQL_HOST="localhost"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD=""
MYSQL_DATABASE="adonis_cms"

# Code/env SMTP config. This is used by booking emails and does not require DB.
SMTP_HOST="mail.adonis.com.bd"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="book@adonis.com.bd"
SMTP_PASS="Book@19700800"
SMTP_FROM_EMAIL="book@adonis.com.bd"
SMTP_ADMIN_EMAILS="info@adonis.com.bd,booking@adonis.com.bd,info@adonis.com.bd,mens.amgcl@gmail.com"
